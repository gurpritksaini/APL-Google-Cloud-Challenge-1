rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // ── /zones/{zoneId} ─────────────────────────────────────────────────────
    // Public read — attendees see live zone data without signing in.
    match /zones/{zoneId} {
      allow read: if true;
      allow write: if false; // Admin SDK only (Cloud Functions)
    }

    // ── /queues/{queueId} ───────────────────────────────────────────────────
    match /queues/{queueId} {
      allow read: if true;
      allow write: if false;
    }

    // ── /alerts/{alertId} ───────────────────────────────────────────────────
    match /alerts/{alertId} {
      allow read: if true;
      allow write: if false;
    }

    // ── /sessions/{sessionId} ───────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if false;
    }

    // ── /events/{eventId} ───────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }

    // ── /attendees/{attendeeId} ─────────────────────────────────────────────
    // Anonymous users can read/write their own document only.
    match /attendees/{attendeeId} {
      allow read, write: if isAuthenticated() && request.auth.uid == attendeeId;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
