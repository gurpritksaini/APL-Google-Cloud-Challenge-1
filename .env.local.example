# ============================================================
# Smart Venue Platform — Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to version control
# ============================================================

# ---- GCP Project ----
NEXT_PUBLIC_GCP_PROJECT_ID=apl--cloud-challenge-1
GCP_REGION=us-central1

# ---- Firebase (Client SDK — safe to expose) ----
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=apl--cloud-challenge-1.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=apl--cloud-challenge-1
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=apl--cloud-challenge-1.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=978400101221
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# ---- Firebase Cloud Messaging ----
NEXT_PUBLIC_FCM_VAPID_KEY=your-vapid-public-key

# ---- Google Maps Platform ----
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-api-key

# ---- Venue location (map centre — defaults to MCG, Melbourne) ----
NEXT_PUBLIC_VENUE_LAT=-37.8199
NEXT_PUBLIC_VENUE_LNG=144.9834

# ---- Cloud Functions (server-side only) ----
# These are loaded from Secret Manager in production
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
BIGQUERY_DATASET=venue_analytics
FCM_SERVER_KEY=your-fcm-server-key

# ---- Pub/Sub Topics ----
PUBSUB_ENTRY_TOPIC=venue-entry-events
PUBSUB_POS_TOPIC=venue-pos-events
PUBSUB_SENSOR_TOPIC=venue-sensor-events
PUBSUB_STAFF_TOPIC=venue-staff-events

# ---- Simulator config ----
SIMULATOR_VENUE_CAPACITY=50000
SIMULATOR_GATE_COUNT=24
SIMULATOR_ZONE_COUNT=8
SIMULATOR_EVENT_DURATION_MIN=180

# ---- Feature Flags ----
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_INDOOR_MAPS=true
NEXT_PUBLIC_ENABLE_NAVIGATION=true
