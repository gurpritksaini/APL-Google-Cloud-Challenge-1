{
  "name": "smart-venue-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Smart Venue Experience Platform — APL Google Cloud Challenge",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "overrides": {
    "firebase-functions": {
      "engines": {
        "node": ">=20"
      }
    }
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "simulate:entries": "tsx scripts/simulators/simulate-entries.ts",
    "simulate:pos": "tsx scripts/simulators/simulate-pos.ts",
    "simulate:sensors": "tsx scripts/simulators/simulate-sensors.ts",
    "simulate:all": "tsx scripts/simulators/run-all.ts",
    "seed": "tsx scripts/seed/seed-firestore.ts",
    "emulate": "firebase emulators:start --import=./emulator-data --export-on-exit",
    "deploy:functions": "cd functions && firebase deploy --only functions",
    "deploy:hosting": "turbo run build --filter=web && firebase deploy --only hosting",
    "deploy:all": "pnpm deploy:functions && pnpm deploy:hosting"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  }
}
